---
import "../styles/components-bookings.css";
import { parseSession, isMember } from "../lib/memberAuth";

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Piano Teacher' } = Astro.props;
const currentPath = Astro.url.pathname;
const session = parseSession(Astro.cookies.get("wixSession"));
const loggedIn = isMember(session);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Piano Teacher</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Patrick+Hand&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav>
      <a href="/" class="logo">🎹 Piano Teacher</a>
      <div class="nav-links">
        <a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a>
        <a href="/services" class:list={[{ active: currentPath.startsWith('/services') }]}>Book a Lesson</a>
        <a href="/plans" class:list={[{ active: currentPath.startsWith('/plans') }]}>Plans</a>
        <a href="/play" class:list={[{ active: currentPath === '/play' }]}>Play Piano</a>
        {loggedIn ? (
          <>
            <a href="/member" class:list={[{ active: currentPath.startsWith('/member') }]}>My Area</a>
            <a href="/logout" class="nav-logout">Sign out</a>
          </>
        ) : (
          <a href="/login" class:list={["nav-login", { active: currentPath === '/login' }]}>Sign in</a>
        )}
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 Piano Teacher. All rights reserved.</p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --paper: #f7f3e8;
    --paper-dark: #ede8d4;
    --paper-card: #fefcf5;
    --pencil: #1a150e;
    --pencil-mid: #6b5a48;
    --pencil-light: #9a8878;
    --gold: #c49238;
    --gold-light: #d4a84e;
    --text: var(--pencil);
    --text-muted: var(--pencil-mid);
    --bg: var(--paper);
    --card-bg: var(--paper-card);
    --border: #c0b4a0;
    --radius: 4px;
    /* legacy alias used by some pages */
    --ebony: var(--pencil);
    --ivory: var(--paper);

    /* booking component tokens */
    --color-accent: var(--gold);
    --color-paper: var(--paper-card);
    --color-cream: var(--paper);
    --color-ink: var(--pencil);
    --color-mute: var(--pencil-light);
    --color-rule: var(--border);
    --color-ink-soft: var(--pencil-mid);
    --color-error: #c43030;
    --font-display: 'Caveat', cursive;
    --font-body: 'Patrick Hand', cursive;
    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-xl: 8px;
    --radius-pill: 999px;
    --shadow-card: 2px 3px 10px rgba(40,28,16,0.1);
  }

  html, body {
    font-family: 'Patrick Hand', cursive;
    background-color: var(--paper);
    background-image:
      linear-gradient(to right,
        transparent 88px,
        rgba(218,140,140,0.4) 88px, rgba(218,140,140,0.4) 89px,
        transparent 89px),
      repeating-linear-gradient(
        transparent, transparent 27px,
        rgba(197,212,232,0.7) 27px, rgba(197,212,232,0.7) 28px
      );
    color: var(--pencil);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-size: 1.05rem;
    line-height: 1.65;
  }

  main { flex: 1; }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 2rem;
    background: var(--paper-dark);
    border-bottom: 1.5px solid rgba(197,212,232,0.9);
    box-shadow: 0 1px 4px rgba(40,28,16,0.06);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: 'Caveat', cursive;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--pencil);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .nav-links { display: flex; gap: 0.25rem; }

  .nav-links a {
    font-family: 'Patrick Hand', cursive;
    color: var(--pencil-mid);
    text-decoration: none;
    padding: 0.4rem 0.9rem;
    border-radius: 3px;
    font-size: 1rem;
    transition: all 0.15s;
  }

  .nav-links a:hover { color: var(--pencil); background: rgba(26,21,14,0.06); }
  .nav-links a.active { color: var(--pencil); font-weight: 700; border-bottom: 2px solid var(--pencil); border-radius: 0; }

  .nav-login {
    background: var(--pencil) !important;
    color: var(--paper) !important;
    padding: 0.35rem 1rem !important;
    border-radius: 3px !important;
    font-weight: 700 !important;
    border-bottom: none !important;
  }
  .nav-login:hover { background: var(--pencil-mid) !important; color: var(--paper) !important; }

  .nav-logout { color: var(--pencil-light) !important; font-size: 0.9rem !important; }

  footer {
    text-align: center;
    padding: 1.5rem;
    font-size: 0.9rem;
    border-top: 1.5px solid rgba(197,212,232,0.9);
    background: var(--paper-dark);
    color: var(--pencil-light);
    font-family: 'Patrick Hand', cursive;
  }

  h1, h2, h3 { font-family: 'Caveat', cursive; font-weight: 700; letter-spacing: 0.01em; }

  @media (max-width: 640px) {
    nav { padding: 0.65rem 1rem; }
    .logo { font-size: 1.35rem; }
    .nav-links a { padding: 0.35rem 0.6rem; font-size: 0.9rem; }
  }
</style>
