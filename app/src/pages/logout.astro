---
import { OAuthStrategy } from "@wix/sdk";

const CLIENT_ID = import.meta.env.WIX_CLIENT_ID as string;
const origin = Astro.url.origin;

// Get logout URL (optional — clears Wix-side session too)
let logoutUrl = "/";
try {
  const session = Astro.cookies.get("wixSession")?.json() as any;
  if (session?.tokens) {
    const auth = OAuthStrategy({ clientId: CLIENT_ID, tokens: session.tokens });
    const result = await auth.logout(origin);
    if (result?.logoutUrl) logoutUrl = result.logoutUrl;
  }
} catch {}

Astro.cookies.delete("wixSession", { path: "/" });
return Astro.redirect(logoutUrl);
---
