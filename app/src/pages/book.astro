---
import Layout from '../layouts/Layout.astro';
import BookingServices from '../components/BookingServices';

// Pre-select tab from query param
const type = Astro.url.searchParams.get('type') ?? 'private';
---

<Layout title="Book a Lesson">
  <div class="page-header">
    <div class="container">
      <h1>Book a Lesson</h1>
      <p>Choose a lesson type and pick a time that works for you.</p>
    </div>
  </div>

  <div class="container booking-layout">
    <BookingServices client:load initialType={type} />
  </div>
</Layout>

<style>
  .page-header {
    background: var(--paper-dark);
    border-bottom: 1.5px solid rgba(197,212,232,0.85);
    padding: 3.5rem 6vw 3rem;
  }
  .page-header h1 { color: var(--pencil); font-size: 2.6rem; margin-bottom: 0.5rem; }
  .page-header p { color: var(--pencil-mid); font-size: 1.05rem; }

  .container { max-width: 1100px; margin: 0 auto; }
  .booking-layout { padding: 3rem 6vw; }

  @media (max-width: 640px) {
    .page-header { padding: 2rem 1.5rem; }
    .booking-layout { padding: 2rem 1.5rem; }
  }
</style>
