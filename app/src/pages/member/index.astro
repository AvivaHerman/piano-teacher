---
import Layout from "../../layouts/Layout.astro";
import { members } from "@wix/members";
import { extendedBookings } from "@wix/bookings";
import { auth } from "@wix/essentials";
import { parseSession, isMember } from "../../lib/memberAuth";

const session = parseSession(Astro.cookies.get("wixSession"));
if (!isMember(session)) return Astro.redirect("/login");

// Fetch current member profile
let member: any = null;
let memberName = "Member";
let memberEmail = "";

try {
  const result: any = await members.getCurrentMember({ fieldsets: ["FULL" as any] });
  member = result?.member ?? result;
  memberName =
    [member?.contact?.firstName ?? member?.profile?.firstName, member?.contact?.lastName ?? member?.profile?.lastName]
      .filter(Boolean)
      .join(" ") ||
    member?.profile?.nickname ||
    member?.loginEmail?.split("@")[0] ||
    "Member";
  memberEmail = member?.loginEmail ?? "";
} catch (err) {
  console.error("[member] getCurrentMember failed:", err);
}

// Fetch upcoming bookings for this member using contactId
let upcomingBookings: any[] = [];
try {
  const contactId = member?.contactId;
  if (contactId) {
    const now = new Date().toISOString();
    const bResult = await auth
      .elevate(extendedBookings.queryExtendedBookings)({
        query: {
          filter: {
            "booking.contactId": { $eq: contactId },
            "booking.status": { $in: ["CREATED", "CONFIRMED", "PENDING"] },
          },
          sort: [{ fieldName: "booking.bookedEntity.slot.startDate", order: "ASC" as const }],
          paging: { limit: 10 },
        },
      })
      .catch(() => null);
    upcomingBookings = (bResult?.extendedBookings ?? []).filter((eb: any) => {
      const start = eb?.booking?.bookedEntity?.slot?.startDate;
      return start && start > now;
    });
  }
} catch (err) {
  console.error("[member] queryExtendedBookings failed:", err);
}

function formatSlotDate(startDate: string | undefined): string {
  if (!startDate) return "TBD";
  return new Date(startDate).toLocaleString("en-US", {
    weekday: "short", month: "short", day: "numeric",
    hour: "2-digit", minute: "2-digit",
  });
}
---

<Layout title="My Area">
  <section class="member-page">
    <header class="member-header">
      <div class="member-avatar">{memberName.charAt(0).toUpperCase()}</div>
      <div class="member-info">
        <h1>Welcome, {memberName}</h1>
        {memberEmail && <p class="member-email">{memberEmail}</p>}
      </div>
    </header>

    <div class="member-actions">
      <a href="/services" class="btn btn-primary">Book a Lesson</a>
      <a href="/logout" class="btn btn-outline-dark">Sign out</a>
    </div>

    <section class="member-section">
      <h2>Upcoming Lessons</h2>
      {upcomingBookings.length === 0 ? (
        <p class="empty-state">
          No upcoming bookings yet.
          <a href="/services">Book your first lesson →</a>
        </p>
      ) : (
        <ul class="booking-list">
          {upcomingBookings.map((eb: any) => {
            const booking = eb.booking;
            const slot = booking?.bookedEntity?.slot;
            const serviceName = slot?.sessionTitle ?? slot?.title ?? "Piano Lesson";
            const startDate = slot?.startDate;
            const status = booking?.status ?? "";
            const coParticipant = booking?.formSubmission?.customFields?.co_participant_name;
            return (
              <li class="booking-card">
                <div class="booking-card-left">
                  <div class="booking-service">{serviceName}</div>
                  <div class="booking-date">{formatSlotDate(startDate)}</div>
                  {coParticipant && (
                    <div class="booking-coparticipant">With: {coParticipant}</div>
                  )}
                </div>
                <div class={`booking-status booking-status--${status.toLowerCase()}`}>
                  {status === "CONFIRMED" ? "Confirmed" :
                   status === "CREATED" ? "Pending" :
                   status === "PENDING" ? "Awaiting confirmation" : status}
                </div>
              </li>
            );
          })}
        </ul>
      )}
    </section>
  </section>
</Layout>

<style>
  .member-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .member-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .member-avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: var(--gold);
    color: var(--ebony);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 700;
    font-family: 'Playfair Display', serif;
    flex-shrink: 0;
  }

  .member-info h1 {
    font-size: 1.9rem;
    margin-bottom: 0.25rem;
  }

  .member-email {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .member-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary { background: var(--gold); color: var(--ebony); }
  .btn-primary:hover { background: var(--gold-light); }

  .btn-outline-dark {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .btn-outline-dark:hover { color: var(--text); border-color: var(--text-muted); }

  .member-section h2 {
    font-size: 1.4rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .empty-state {
    color: var(--text-muted);
    padding: 2rem 0;
  }

  .empty-state a { color: var(--gold); text-decoration: none; }
  .empty-state a:hover { text-decoration: underline; }

  .booking-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .booking-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    gap: 1rem;
  }

  .booking-service {
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .booking-date {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .booking-coparticipant {
    color: var(--gold);
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }

  .booking-status {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.3rem 0.85rem;
    border-radius: 99px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .booking-status--confirmed { background: #d4f0dc; color: #276749; }
  .booking-status--created { background: #fef3c7; color: #92400e; }
  .booking-status--pending { background: #e0f2fe; color: #0369a1; }
</style>
