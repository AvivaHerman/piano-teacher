---
import { parseSession, isMember } from "../lib/memberAuth";

const session = parseSession(Astro.cookies.get("wixSession"));
if (isMember(session)) return Astro.redirect("/member");

const returnTo = Astro.url.searchParams.get("redirect") ?? Astro.url.searchParams.get("returnTo") ?? "/member";
return Astro.redirect(`/api/auth/login?returnTo=${encodeURIComponent(returnTo)}`);
