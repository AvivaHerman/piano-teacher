---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-content">
      <div class="badge">Professional Piano Instruction</div>
      <h1>Learn Piano<br />at Any Level</h1>
      <p>Private, couples, and group lessons tailored to you — from beginner to advanced. Plus a fun interactive piano game for kids!</p>
      <div class="hero-actions">
        <a href="/services" class="btn btn-primary">Book a Lesson</a>
        <a href="/play" class="btn btn-outline">Try the Piano Game</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <img
        src="/piano-keys.png"
        alt="Piano keyboard"
        class="hero-piano-photo"
      />
    </div>

    <!-- ── Hand-drawn note decorations ── -->
    <div class="music-bg" aria-hidden="true">

      <!-- Treble clef — top-left, large, very faint -->
      <svg class="mn" style="top:-3%;left:0%;width:100px;" viewBox="0 0 44 120">
        <text x="0" y="115" font-family="Georgia,serif" font-size="112" fill="currentColor">𝄞</text>
      </svg>

      <!-- Beamed pair — top-right -->
      <svg class="mn" style="top:5%;right:1%;width:130px;transform:rotate(9deg);" viewBox="0 0 85 70">
        <ellipse cx="14" cy="60" rx="14" ry="9" transform="rotate(-18 14 60)" fill="currentColor"/>
        <ellipse cx="58" cy="52" rx="14" ry="9" transform="rotate(-18 58 52)" fill="currentColor"/>
        <line x1="26" y1="55" x2="26" y2="10" stroke="currentColor" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="70" y1="47" x2="70" y2="2"  stroke="currentColor" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="26" y1="10" x2="70" y2="2"  stroke="currentColor" stroke-width="8"   stroke-linecap="round"/>
      </svg>

      <!-- Eighth note — left side, mid -->
      <svg class="mn" style="top:44%;left:0%;width:68px;transform:rotate(-13deg);" viewBox="0 0 44 66">
        <ellipse cx="14" cy="57" rx="13" ry="9" transform="rotate(-18 14 57)" fill="currentColor"/>
        <line x1="25" y1="52" x2="25" y2="7" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
        <path d="M25 7 C40 13 44 27 33 41" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
      </svg>

      <!-- Quarter note — bottom-left -->
      <svg class="mn" style="bottom:7%;left:7%;width:58px;transform:rotate(-7deg);" viewBox="0 0 36 70">
        <ellipse cx="12" cy="60" rx="13" ry="9" transform="rotate(-18 12 60)" fill="currentColor"/>
        <line x1="24" y1="55" x2="24" y2="4" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
      </svg>

      <!-- Beamed triple (sixteenths) — bottom-centre -->
      <svg class="mn" style="bottom:4%;left:34%;width:150px;transform:rotate(-4deg);" viewBox="0 0 115 72">
        <ellipse cx="12"  cy="62" rx="12" ry="8" transform="rotate(-18 12  62)" fill="currentColor"/>
        <ellipse cx="52"  cy="56" rx="12" ry="8" transform="rotate(-18 52  56)" fill="currentColor"/>
        <ellipse cx="92"  cy="50" rx="12" ry="8" transform="rotate(-18 92  50)" fill="currentColor"/>
        <line x1="23" y1="57" x2="23" y2="10" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
        <line x1="63" y1="51" x2="63" y2="4"  stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
        <line x1="103" y1="45" x2="103" y2="-2" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
        <line x1="23" y1="10" x2="103" y2="-2" stroke="currentColor" stroke-width="6.5" stroke-linecap="round"/>
        <line x1="23" y1="20" x2="103" y2="8"  stroke="currentColor" stroke-width="6.5" stroke-linecap="round"/>
      </svg>

      <!-- Single eighth note — right, lower-mid -->
      <svg class="mn" style="bottom:18%;right:1%;width:60px;transform:rotate(7deg);" viewBox="0 0 44 66">
        <ellipse cx="14" cy="57" rx="13" ry="9" transform="rotate(-18 14 57)" fill="currentColor"/>
        <line x1="25" y1="52" x2="25" y2="7" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
        <path d="M25 7 C40 13 44 27 33 41" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
      </svg>

      <!-- Small quarter note — top centre, just above hero content -->
      <svg class="mn" style="top:3%;left:46%;width:44px;transform:rotate(4deg);opacity:0.05;" viewBox="0 0 36 70">
        <ellipse cx="12" cy="60" rx="13" ry="9" transform="rotate(-18 12 60)" fill="currentColor"/>
        <line x1="24" y1="55" x2="24" y2="4" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
      </svg>

    </div>
  </section>

  <section class="lessons">
    <div class="section-notes" aria-hidden="true">
      <!-- Quarter note — top-left corner of lessons -->
      <svg class="mn" style="top:5%;left:0%;width:52px;transform:rotate(-9deg);" viewBox="0 0 36 70">
        <ellipse cx="12" cy="60" rx="13" ry="9" transform="rotate(-18 12 60)" fill="currentColor"/>
        <line x1="24" y1="55" x2="24" y2="4" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
      </svg>
      <!-- Beamed pair — bottom-right -->
      <svg class="mn" style="bottom:3%;right:1%;width:110px;transform:rotate(11deg);" viewBox="0 0 85 70">
        <ellipse cx="14" cy="60" rx="14" ry="9" transform="rotate(-18 14 60)" fill="currentColor"/>
        <ellipse cx="58" cy="52" rx="14" ry="9" transform="rotate(-18 58 52)" fill="currentColor"/>
        <line x1="26" y1="55" x2="26" y2="10" stroke="currentColor" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="70" y1="47" x2="70" y2="2"  stroke="currentColor" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="26" y1="10" x2="70" y2="2"  stroke="currentColor" stroke-width="8"   stroke-linecap="round"/>
      </svg>
    </div>
    <div class="container">
      <h2>Lesson Types</h2>
      <p class="section-subtitle">Choose the format that works best for you</p>
      <div class="cards">
        <div class="card">
          <div class="card-icon">🎹</div>
          <h3>Private Lessons</h3>
          <p>One-on-one sessions fully tailored to your pace and goals. The fastest way to progress.</p>
          <ul>
            <li>Personalised curriculum</li>
            <li>Flexible scheduling</li>
            <li>30 or 60 minute sessions</li>
          </ul>
          <a href="/services/private-lesson" class="btn btn-secondary">Book Private</a>
        </div>
        <div class="card featured">
          <div class="badge-popular">Most Popular</div>
          <div class="card-icon">👫</div>
          <h3>Couples Lessons</h3>
          <p>Perfect for friends, siblings, or partners who want to learn together and share the joy of music.</p>
          <ul>
            <li>Duet repertoire</li>
            <li>Collaborative learning</li>
            <li>More affordable per person</li>
          </ul>
          <a href="/services/couples-lesson" class="btn btn-primary">Book Couples</a>
        </div>
        <div class="card">
          <div class="card-icon">🎵</div>
          <h3>Group Lessons</h3>
          <p>Fun, social sessions for 3–6 students. Great for children and beginner adults.</p>
          <ul>
            <li>Group of 3–6 students</li>
            <li>Games and ensemble play</li>
            <li>Most budget-friendly</li>
          </ul>
          <a href="/services/group-lesson" class="btn btn-secondary">Book Group</a>
        </div>
      </div>
    </div>
  </section>

  <section class="game-promo">
    <div class="section-notes" aria-hidden="true">
      <!-- Treble clef — right edge, faint -->
      <svg class="mn" style="top:-5%;right:-1%;width:88px;opacity:0.05;" viewBox="0 0 44 120">
        <text x="0" y="115" font-family="Georgia,serif" font-size="112" fill="currentColor">𝄞</text>
      </svg>
      <!-- Eighth note — lower-left -->
      <svg class="mn" style="bottom:5%;left:1%;width:62px;transform:rotate(-11deg);" viewBox="0 0 44 66">
        <ellipse cx="14" cy="57" rx="13" ry="9" transform="rotate(-18 14 57)" fill="currentColor"/>
        <line x1="25" y1="52" x2="25" y2="7" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
        <path d="M25 7 C40 13 44 27 33 41" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="container">
      <div class="promo-content">
        <div class="promo-text">
          <h2>Practice Makes Perfect</h2>
          <p>Our interactive piano game lets students practise favourite children's songs right in the browser — no instrument needed. Members can add their own songs to their personal playlist.</p>
          <a href="/play" class="btn btn-primary">Open the Piano Game</a>
        </div>
        <div class="promo-keys" aria-hidden="true">🎹</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .hero {
    min-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4rem 6vw;
    gap: 3rem;
    border-bottom: 1.5px solid rgba(197,212,232,0.8);
    position: relative;
  }

  .hero-content { max-width: 560px; z-index: 1; }

  .badge {
    display: inline-block;
    background: rgba(196,146,56,0.1);
    border: 1.5px solid rgba(196,146,56,0.35);
    color: var(--gold);
    font-family: 'Patrick Hand', cursive;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 2px;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 1.05;
    color: var(--pencil);
    margin-bottom: 1.25rem;
  }

  .hero p {
    font-size: 1.15rem;
    color: var(--pencil-mid);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 3px;
    font-family: 'Patrick Hand', cursive;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer;
    letter-spacing: 0.02em;
  }

  .btn-primary {
    background: var(--pencil);
    color: var(--paper);
    border: 2px solid var(--pencil);
  }
  .btn-primary:hover { background: var(--pencil-mid); border-color: var(--pencil-mid); }

  .btn-outline {
    background: transparent;
    color: var(--pencil);
    border: 2px solid var(--pencil);
  }
  .btn-outline:hover { background: rgba(26,21,14,0.05); }

  .btn-secondary {
    background: transparent;
    color: var(--gold);
    border: 2px solid var(--gold);
  }
  .btn-secondary:hover { background: rgba(196,146,56,0.07); }

  /* hero piano photo */
  .hero-visual {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
  }
  .hero-piano-photo {
    width: 100%;
    height: auto;
    display: block;
    transform: scaleY(-1);
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 8%, black 82%, transparent 100%);
    mask-image:
      linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 8%, black 82%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
  }

  /* ── Lessons ──────────────────────────────────────────────────────────────── */
  .lessons { padding: 6rem 6vw; }
  .container { max-width: 1100px; margin: 0 auto; }

  .lessons h2, .game-promo h2 { text-align: center; font-size: clamp(2rem, 4vw, 2.8rem); margin-bottom: 0.5rem; }
  .section-subtitle { text-align: center; color: var(--pencil-mid); font-size: 1.05rem; margin-bottom: 3rem; }

  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }

  .card {
    background: var(--paper-card);
    border: 1.5px solid var(--border);
    border-radius: 3px;
    padding: 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: 2px 3px 8px rgba(40,28,16,0.07);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .card:hover { box-shadow: 4px 5px 14px rgba(40,28,16,0.12); transform: translateY(-2px) rotate(0.2deg); }
  .card.featured { border-color: var(--gold); border-width: 2px; box-shadow: 3px 4px 12px rgba(196,146,56,0.15); }

  .badge-popular {
    position: absolute;
    top: -12px; left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--paper);
    font-family: 'Patrick Hand', cursive;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.2rem 0.9rem;
    border-radius: 2px;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  .card-icon { font-size: 2.25rem; }
  .card h3 { font-size: 1.5rem; }
  .card p { color: var(--pencil-mid); line-height: 1.6; }
  .card ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .card ul li::before { content: '— '; color: var(--gold); font-weight: 700; }
  .card ul li { font-size: 0.95rem; color: var(--pencil-mid); }
  .card .btn { margin-top: auto; text-align: center; }

  /* ── Game promo ───────────────────────────────────────────────────────────── */
  .game-promo {
    background: var(--paper-dark);
    border-top: 1.5px solid rgba(197,212,232,0.8);
    border-bottom: 1.5px solid rgba(197,212,232,0.8);
    padding: 5rem 6vw;
  }

  .promo-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .promo-text { max-width: 540px; }
  .promo-text h2 { color: var(--pencil); font-size: clamp(1.9rem, 3.5vw, 2.6rem); margin-bottom: 1rem; }
  .promo-text p { color: var(--pencil-mid); font-size: 1.05rem; line-height: 1.7; margin-bottom: 1.75rem; }

  .promo-keys { font-size: 8rem; opacity: 0.12; flex-shrink: 0; }

  /* ── Musical note decorations ─────────────────────────────────────────── */
  .music-bg, .section-notes {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 0;
  }
  .mn { position: absolute; color: var(--pencil); opacity: 0.07; }
  .hero-content, .hero-visual { position: relative; z-index: 1; }
  .lessons { position: relative; overflow: hidden; }
  .game-promo { position: relative; overflow: hidden; }

  @media (max-width: 768px) {
    .hero { flex-direction: column; text-align: center; justify-content: center; padding: 3rem 1.5rem; }
    .hero-actions { justify-content: center; }
    .hero-visual { display: none; }
    .promo-content { flex-direction: column; text-align: center; }
    .promo-keys { display: none; }
    .lessons, .game-promo { padding: 3.5rem 1.5rem; }
  }
</style>
