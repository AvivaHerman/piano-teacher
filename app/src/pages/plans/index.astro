---
import Layout from "../../layouts/Layout.astro";
import { plansV3 } from "@wix/pricing-plans";
import { auth } from "@wix/essentials";
import { parseSession, isMember } from "../../lib/memberAuth";

const session = parseSession(Astro.cookies.get("wixSession"));
const loggedIn = isMember(session);

let planList: any[] = [];
try {
  const result = await auth.elevate(plansV3.queryPlans)().find();
  planList = (result?.items ?? []).filter(
    (p: any) => p.visibility === "PUBLIC" || p.visibility === 1
  );
} catch (err) {
  console.error("[plans] queryPlans failed:", err);
}

function formatPrice(plan: any): string {
  const amount = plan.pricingVariants?.[0]?.pricingStrategies?.[0]?.flatRate?.amount;
  if (!amount || Number(amount) === 0) return "Free";
  const currency = plan.currency ?? "USD";
  try {
    return new Intl.NumberFormat("en-US", { style: "currency", currency }).format(
      Number(amount)
    );
  } catch {
    return `$${amount}`;
  }
}

function getBillingLabel(plan: any): string {
  const billingTerms = plan.pricingVariants?.[0]?.billingTerms;
  if (!billingTerms) return "";
  const endType = billingTerms.endType;
  if (endType === "UNTIL_CANCELLED" || endType === "UNTIL_CANCELED") {
    const period = (billingTerms.billingCycle?.period ?? "MONTH").toLowerCase();
    return `/ ${period}`;
  }
  return "one-time";
}

const planId = (plan: any): string => plan._id ?? plan.id ?? "";
---

<Layout title="Lesson Plans">
  <section class="plans-page">
    <header class="plans-header">
      <h1>Lesson Plans</h1>
      <p>Choose the plan that fits your practice goals</p>
    </header>

    {planList.length === 0 ? (
      <p class="plans-empty">Plans coming soon — check back shortly.</p>
    ) : (
      <div class="plans-grid">
        {planList.map((plan: any) => (
          <div class="plan-card">
            <div class="plan-name">{plan.name}</div>
            <div class="plan-price-row">
              <span class="plan-price">{formatPrice(plan)}</span>
              {getBillingLabel(plan) && (
                <span class="plan-billing">{getBillingLabel(plan)}</span>
              )}
            </div>
            {plan.description && (
              <p class="plan-desc">{plan.description}</p>
            )}
            {plan.perks?.length > 0 && (
              <ul class="plan-perks">
                {plan.perks.map((perk: any) => (
                  <li>{perk.description}</li>
                ))}
              </ul>
            )}
            <div class="plan-cta">
              {loggedIn ? (
                <button class="btn-plan" data-plan-id={planId(plan)}>
                  Get Started
                </button>
              ) : (
                <a href="/login?redirect=/plans" class="btn-plan btn-plan--link">
                  Sign in to Subscribe
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll<HTMLButtonElement>("button.btn-plan").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const planId = btn.dataset.planId;
        if (!planId) return;
        btn.disabled = true;
        btn.textContent = "Loading…";
        try {
          const res = await fetch("/api/plans/checkout", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ planId }),
          });
          const data = await res.json();
          if (data.url) {
            window.location.href = data.url;
          } else {
            throw new Error(data.error ?? "No checkout URL returned");
          }
        } catch (err) {
          console.error("[plans] checkout error:", err);
          btn.disabled = false;
          btn.textContent = "Get Started";
          alert("Something went wrong. Please try again.");
        }
      });
    });
  });
</script>

<style>
  .plans-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .plans-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .plans-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .plans-header p {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .plans-empty {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .plan-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .plan-name {
    font-family: "Caveat", cursive;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .plan-price {
    font-family: "Caveat", cursive;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
  }

  .plan-billing {
    font-family: "Patrick Hand", cursive;
    font-size: 1rem;
    color: var(--text-muted);
  }

  .plan-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .plan-perks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .plan-perks li {
    font-size: 0.95rem;
    color: var(--text);
  }

  .plan-perks li::before {
    content: "✓ ";
    color: var(--gold);
    font-weight: 700;
  }

  .plan-cta {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .btn-plan {
    display: block;
    width: 100%;
    padding: 0.8rem 1.5rem;
    background: var(--pencil);
    color: var(--paper);
    border: none;
    border-radius: var(--radius);
    font-family: "Patrick Hand", cursive;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: background 0.15s;
  }

  .btn-plan:hover:not(:disabled) {
    background: var(--pencil-mid);
  }

  .btn-plan:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .btn-plan--link {
    background: var(--pencil-light);
  }

  .btn-plan--link:hover {
    background: var(--pencil-mid);
  }
</style>
